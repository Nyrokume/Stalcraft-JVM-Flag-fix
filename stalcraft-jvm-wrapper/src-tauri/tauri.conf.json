{
  "$schema": "https://raw.githubusercontent.com/nicklasgossman/tauri/main/crates/tauri-config-schema/schema.json",
  "productName": "STALCRAFT JVM Wrapper",
  "version": "1.0.0",
  "identifier": "com.nyrok.stalcraft-jvm-wrapper",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "STALCRAFT JVM Wrapper",
        "width": 1350,
        "height": 1030,
        "minWidth": 900,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
